# ═══════════════════════════════════════════════════════════════════════════════
# SEARCHATLAS CLIENT DASHBOARD - PRODUCTION CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
#
# QUICK SETUP:
#   1. Copy this file to .env.local
#   2. Add your EMAILBISON_API_TOKEN (get from team lead or EmailBison dashboard)
#   3. Run: npm install && npm run build && npm start
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── EMAILBISON API (Analytics Tab) ─────────────────────────────────────────────
# Production endpoint (pre-configured)
EMAILBISON_API_URL=https://spellcast.hirecharm.com

# ⚠️  REQUIRED: Get this token from your team lead or EmailBison dashboard
#     Navigate to: EmailBison → Settings → API → Generate Token
EMAILBISON_API_TOKEN=

# ── INFRASTRUCTURE API (Infrastructure Tab) ────────────────────────────────────
# Charm OS API endpoint for SearchAtlas infrastructure data
# Production: http://ccssgc4gowsog04wck400o0w.31.97.142.123.sslip.io
# Local dev:  http://localhost:8000
INFRASTRUCTURE_API_URL=http://ccssgc4gowsog04wck400o0w.31.97.142.123.sslip.io

# SearchAtlas client UUID in Charm OS database
# TODO: Update with actual SearchAtlas client ID from database
INFRASTRUCTURE_CLIENT_ID=4bd07dc0-059a-448b-b6f4-3275d0c104a9

# ── OPTIONAL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_DASHBOARD_TITLE=SearchAtlas Dashboard
NEXT_PUBLIC_AUTO_REFRESH_MS=300000

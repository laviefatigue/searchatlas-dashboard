# ═══════════════════════════════════════════════════════════════════════════════
# CLIENT ANALYTICS DASHBOARD - MULTI-TENANT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
#
# QUICK SETUP:
#   1. Copy this file to .env.local
#   2. Add your EMAILBISON_API_TOKEN
#   3. Set WORKSPACE_ID and WORKSPACE_NAME for the target client
#   4. Run: npm install && npm run build && npm start
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── EMAILBISON API (Analytics Tab) ─────────────────────────────────────────────
# Production endpoint (pre-configured)
EMAILBISON_API_URL=https://spellcast.hirecharm.com

# ⚠️  REQUIRED: Get this token from your team lead or EmailBison dashboard
#     Navigate to: EmailBison → Settings → API → Generate Token
EMAILBISON_API_TOKEN=

# ── WORKSPACE CONFIGURATION (Multi-Tenant) ─────────────────────────────────────
# Each deployment targets a specific EmailBison workspace
#
# WORKSPACE_ID: The numeric team_id from EmailBison
#   - Find in EmailBison: Settings → Workspace → look at URL or API calls
#   - Examples: 22 (Selery), 24 (Search Atlas)
#
# WORKSPACE_NAME: Display name shown in dashboard header
#   - This is purely cosmetic for the UI
#
WORKSPACE_ID=
WORKSPACE_NAME=Dashboard

# ── INFRASTRUCTURE API (Infrastructure Tab) ────────────────────────────────────
# Charm OS API endpoint for infrastructure health data
# Production: http://ccssgc4gowsog04wck400o0w.31.97.142.123.sslip.io
# Local dev:  http://localhost:8000
INFRASTRUCTURE_API_URL=http://ccssgc4gowsog04wck400o0w.31.97.142.123.sslip.io

# Client UUID in Charm OS database (for Infrastructure tab)
INFRASTRUCTURE_CLIENT_ID=

# ── OPTIONAL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_DASHBOARD_TITLE=Client Dashboard
NEXT_PUBLIC_AUTO_REFRESH_MS=300000

# AI Features (for enrichment and advanced analytics)
ANTHROPIC_API_KEY=
AI_ARK_API_KEY=

# ── DASHBOARD SECURITY ────────────────────────────────────────────────────────
# Simple password protection for the dashboard
# Set this to a secure password to enable login requirement
DASHBOARD_PASSWORD=
